# Track 2 injects NO api key/model restriction — use your own credentials.
# For local dev, copy this to .env. Do NOT bundle a real .env into the
# submitted Docker image; the Fireworks key is baked at build time via
# --build-arg (see README.md).

# Required: Fireworks credentials (the only credential that goes in the image)
FIREWORKS_API_KEY=your_fireworks_api_key_here
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1

# LOCAL EVAL ONLY — powers the Gemini vision judge in scripts/local_eval.py.
# NEVER pass this as --build-arg and never bake it into the image: the
# submitted image is publicly pullable, so anything inside it can be read.
OPENROUTER_API_KEY=

# --- v6 primary engine (qwen_direct): frames straight to the vision model,
#     one call per style, deterministic guards only. ---
CAPTION_ASSEMBLY=qwen_direct
QWEN_DIRECT_FRAMES=4
QWEN_DIRECT_FRAME_MAX_WIDTH=1024
QWEN_DIRECT_MAX_TOKENS=400
QWEN_DIRECT_TEMPERATURE=0.7
QWEN_DIRECT_GUARD_LEVEL=1
# Optional per-style temperature overrides (submission rung R2):
#QWEN_DIRECT_TEMP_FORMAL=0.3
#QWEN_DIRECT_TEMP_SARCASTIC=0.7
#QWEN_DIRECT_TEMP_HUMOROUS_TECH=0.8
#QWEN_DIRECT_TEMP_HUMOROUS_NON_TECH=0.8

# --- legacy_v5 engine (rollback only; CAPTION_ASSEMBLY=legacy_v5) ---
ENABLE_NATIVE_VIDEO=true
FIREWORKS_NATIVE_VIDEO_MODEL=accounts/fireworks/models/minimax-m3
FIREWORKS_NATIVE_VIDEO_TIMEOUT_SECONDS=90
ENABLE_REPORT_VERIFICATION=true
FIREWORKS_VERIFY_TIMEOUT_SECONDS=45
VERIFY_MIN_TIME_REMAINING_SECONDS=180
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p7-code
FIREWORKS_VISION_FALLBACK_MODEL=accounts/fireworks/models/qwen3p7-plus
FIREWORKS_TEXT_MODEL=accounts/fireworks/models/glm-5p2
FIREWORKS_JUDGE_MODEL=accounts/fireworks/models/qwen3p7-plus
BEST_OF_N=5
ENABLE_SELF_CRITIQUE=true
ENABLE_JUDGE_POLISH=false
MAX_CRITIQUE_RETRIES=2
CRITIQUE_PASS_THRESHOLD=8

# Local dev convenience: cache downloaded clips in scratch_videos/
KEEP_DOWNLOADS=false

# Orchestration — hard ceiling is 10 minutes total for ~12 hidden clips.
# Local runs on home bandwidth: use CONCURRENCY=1 and raise
# TOTAL_BUDGET_SECONDS / MAX_DOWNLOAD_WALL_SECONDS instead.
CONCURRENCY=4
TOTAL_BUDGET_SECONDS=540
PER_REQUEST_TIMEOUT_SECONDS=28
MAX_DOWNLOAD_WALL_SECONDS=150

# Salvage pass: after the main run, re-attempt any style that shipped a
# generic fallback caption, using the (huge) leftover time budget.
ENABLE_SALVAGE_PASS=true
SALVAGE_MIN_TIME_REMAINING_SECONDS=90
SALVAGE_ROUND_PAUSE_SECONDS=15
MAX_SALVAGE_ROUNDS=3
